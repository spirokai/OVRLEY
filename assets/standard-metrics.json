          "tick_alignment": "below",
          "show_minor_labels": true,
          "show_major_labels": true,
          "label_color": "#cccccc",
          "cardinal_label_color": "#ff0000",
          "label_font": "Arial.ttf",
          "label_font_size": 12,
          "label_offset": 4,
          "indicator_style": "chevron",
          "indicator_placement": "top",
          "show_indicator": true,
          "indicator_color": "#ff0000",
          "indicator_size": 10
        }
      },
      "linear": {
        "label": "Linear",
        "layoutMode": "boxed",
        "defaultFrameWidth": 200,
        "defaultFrameHeight": 60
      },
      "bars": {
