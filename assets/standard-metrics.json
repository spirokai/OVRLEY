            "balance_format": "percent_label"
          }
        }
      },
      "heading_tape": {
        "label": "Heading Tape",
        "layoutMode": "boxed",
        "defaultFrameWidth": 200,
        "defaultFrameHeight": 60,
        "defaults": {
          "pixels_per_degree": 5,
          "major_tick_interval": 15,
          "minor_ticks_per_major": 3,
          "show_major_ticks": true,
          "show_minor_ticks": true,
