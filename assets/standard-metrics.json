  "displayTypes": {
    "definitions": {
      "text": {
        "label": "Text",
        "layoutMode": "intrinsic",
        "defaults": {
          "x": 100,
          "y": 100,
          "prefix": "",
          "suffix": "",
          "decimals": 0,
